# Copy this file to .env.local and fill in the values.

# Gmail account used to send the website quote emails.
EMAIL_USER=your-gmail@gmail.com
# Gmail App Password (NOT your normal password). 16 characters.
EMAIL_PASS=your-app-password

# Recipient for quote submissions.
QUOTE_TO=STAGGMANAGEMENT@gmail.com

# OPTIONAL: only needed if EMAIL_USER is NOT a Gmail address.
# Your domain's outgoing mail server, e.g.:
#   EMAIL_HOST=mail.stagfencing.com.au
#   EMAIL_PORT=465   (use 465 for SSL, or 587 for TLS)
# EMAIL_HOST=
# EMAIL_PORT=587
